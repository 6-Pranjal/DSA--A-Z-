import java.util.*;
class Main {
    public static void decreasing_num(int n){
        if(n==0){
            return;
        }
        System.out.println(n);
        decreasing_num(n-1);
        //    System.out.println(n);   increasing order
        return;
    }
    
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        decreasing_num(n);
        
    }
}