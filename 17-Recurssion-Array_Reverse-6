
import java.util.*;
class Main {
    
    public static int reverse_array(int[] arr,int n){
        if(n==0){
            return arr[0];
        }
        
        System.out.print(arr[n] + " " );
        return reverse_array(arr,n-1);
        
    }
    
    public static void main(String[] args) {
        int[] arr={1,3,4,5,6,6,7,7,8,8};
        int n =arr.length;
        System.out.println(reverse_array(arr ,n-1));
    }
}