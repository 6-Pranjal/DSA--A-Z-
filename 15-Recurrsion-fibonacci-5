
import java.util.*;
class Main {
    public static int fibonacci(int n){
        if(n==1){
            return 1;
        }
        else if(n==0){
            return 0;
        }
        
        int fn=fibonacci(n-1)+fibonacci(n-2);
        return fn;
        
    }
    
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        System.out.println(fibonacci(n));
        
    }
}
   
